# Bluesky identifier — your handle (e.g. alice.bsky.social) or DID.
BLUESKY_IDENTIFIER=

# Bluesky app password — generate at https://bsky.app/settings/app-passwords.
# Do NOT use your account password.
BLUESKY_APP_PASSWORD=

# Optional — override the PDS service URL. Defaults to https://bsky.social.
# BLUESKY_SERVICE=https://bsky.social

# Long random string used to gate access to the MCP endpoint.
# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=

# HMAC key used to sign short-lived upload URLs for the image-attachment flow.
# Must be a separate secret from MCP_BEARER_TOKEN.
# Generate with: openssl rand -hex 32
MCP_UPLOAD_SIGNING_SECRET=
